---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Meu Site" } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;700&family=Geist+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-[var(--background)] text-[var(--foreground)] font-sans antialiased">
    
    <div class="scanlines pointer-events-none fixed inset-0 z-50 opacity-[0.03]" aria-hidden="true"></div>
    <div class="glitch-flash pointer-events-none fixed inset-0 z-40 opacity-0" aria-hidden="true"></div>
    
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --font-geist-sans: "Geist", system-ui, sans-serif;
    --font-geist-mono: "Geist Mono", monospace;
  }
  body {
    font-family: var(--font-geist-sans);
  }
  code,
  .font-mono {
    font-family: var(--font-geist-mono);
  }
</style>