---
import Layout from '../layouts/Layout.astro';
import Bento from '../components/Bento.astro';
import StampsScroll from '../components/StampsScroll.astro';
---

<Layout title="null's site">
  <div class="min-h-screen px-4 md:px-20 py-6 flex flex-col gap-5">

    <!-- Chapter title card -->
    <div class="chapter-card">
      <span class="chapter-number">∴ &nbsp; Chapter I &nbsp; ∴</span>
      <span class="chapter-title">The Shadow Mountains</span>
      <div class="chapter-rule">⸸</div>
    </div>

    <!-- Header -->
    <header class="p-5 grimoire-card" style="background: var(--theme-surface); border: 1px solid var(--theme-border);">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 items-center">

        <div class="md:col-span-2 flex items-center justify-center">
          <div class="relative w-full max-w-lg aspect-[4/3] overflow-hidden shadow-2xl">
            <img
              src="/about-me.jpg"
              alt="Profile photo"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            />
            <div
              class="absolute inset-0"
              style="background: linear-gradient(to top, var(--theme-surface-alpha), transparent);"
            ></div>
          </div>
        </div>

        <div class="md:col-span-1 text-center md:text-left flex flex-col gap-4 items-center md:items-start">
          <p class="text-sm leading-relaxed max-w-sm md:max-w-none" style="color: var(--theme-text-muted);">
            23y, Brazilian 🇧🇷 | Data Engineer Intern | CS Student (questioning life choices) |
            ADHD brain | HSK02 Certified (Mandarin on pause) |
            Seeking my true path in life.
          </p>
          <!-- Parental Advisory badge -->
          <div class="parental-advisory self-start">
            <span class="pa-icon">⚠</span>
            <div>
              <span class="pa-text-main">Parental Advisory</span>
              <span class="pa-text-sub">Explicit Content</span>
            </div>
          </div>
        </div>

      </div>
    </header>

    <!-- Main layout -->
    <div class="flex flex-col md:flex-row gap-5 flex-1">

      <!-- Sidebar nav -->
      <aside class="flex flex-col gap-4 w-full md:w-fit">
        <nav class="p-5 w-full md:min-w-60 flex flex-col gap-3 grimoire-card"
             style="background: var(--theme-surface); border: 1px solid var(--theme-border);">

          <!-- Nav header -->
          <div class="grimoire-label text-center pb-3"
               style="border-bottom: 1px solid var(--theme-border);">
            ⸸ &nbsp; The Codex &nbsp; ⸸
          </div>

          <ul class="space-y-2 flex-1">
            <li>
              <a href="/about"
                 class="flex items-center gap-2 text-sm transition-colors duration-200"
                 style="font-family: var(--font-gothic); color: var(--theme-text);"
                 onmouseover="this.style.color='var(--theme-accent-bright)'"
                 onmouseout="this.style.color='var(--theme-text)'">
                <span style="color: var(--theme-accent-bright);">→</span>
                My Character Sheet
              </a>
            </li>
            <li>
              <a href="/blog"
                 class="flex items-center gap-2 text-sm transition-colors duration-200"
                 style="font-family: var(--font-gothic); color: var(--theme-text);"
                 onmouseover="this.style.color='var(--theme-accent-bright)'"
                 onmouseout="this.style.color='var(--theme-text)'">
                <span style="color: var(--theme-accent-bright);">→</span>
                Blog
              </a>
            </li>
            {[
              'Recommendations',
              'Guest Book',
              'DIY Projects',
              'Stuff',
            ].map(item => (
              <li class="flex items-center gap-2 text-sm" style="font-family: var(--font-gothic); color: var(--theme-text-subtle);">
                <span>⊘</span>
                <span>{item}</span>
                <span class="ml-auto grimoire-label" style="font-size: 0.45rem; letter-spacing: 0.15em;">[sealed]</span>
              </li>
            ))}
          </ul>

          <!-- Index of forbidden knowledge note -->
          <div class="grimoire-label text-center pt-3" style="border-top: 1px solid var(--theme-border); font-size: 0.45rem;">
            Index of Forbidden Knowledge
          </div>
        </nav>
      </aside>

      <!-- Content -->
      <div class="flex flex-col gap-5 flex-1">
        <main id="main-content" class="flex-1">
          <Bento />
        </main>

        <!-- Divider before stamps -->
        <div class="sigil-divider px-4">⸸ &nbsp; Relics &nbsp; ⸸</div>

        <div class="px-4 pb-6 flex items-center justify-center">
          <StampsScroll />
        </div>
      </div>

    </div>

  </div>
</Layout>
