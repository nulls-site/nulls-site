---
import Layout from '../layouts/Layout.astro';
import Bento from '../components/Bento.astro';
import StampsScroll from '../components/StampsScroll.astro';
---

<Layout title="Home | Meu Site">
  <div class="min-h-screen px-4 md:px-20 py-10 flex flex-col">
    
    <!-- Header About -->
    <header class="bg-mandy-purple mb-5 p-5">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 items-center">
        
        <!-- Imagem -->
        <div class="md:col-span-2 flex items-center justify-center">
          <div class="relative w-full max-w-lg aspect-[4/3] overflow-hidden rounded-lg shadow-2xl">
            <img 
              src="/about-me.jpg" 
              alt="Foto de perfil"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            />
            <!-- Gradiente atualizado com cor da paleta -->
            <div class="absolute inset-0 bg-gradient-to-t from-mandy-purple/50 to-transparent"></div>
          </div>
        </div>

        <!-- Texto -->
        <div class="md:col-span-1 text-center md:text-left">
          <p class="text-sm md:text-base text-mandy-white/80 leading-relaxed mb-4">
            23y, Brazilian 🇧🇷 | Data Engineer Intern | CS Student (questioning life choices) | 
            ADHD brain  | HSK02 Certified (Mandarin on pause) | 
            Seeking my true path in life.
          </p>
        </div>

      </div>
    </header>

    <!-- Main Grid -->
    <div class="flex gap-5 flex-1">
      
      <!-- Sidebar -->
      <aside class="flex flex-col gap-2 w-fit">
        <nav class="bg-mandy-purple p-5 min-w-60 min-h-60">
          <ul class="space-y-2">
            <li><a href="/about" class="text-mandy-white hover:text-mandy-yellow transition-colors">My Character Sheet</a></li>
            <li><a class="disabled text-mandy-white/40 cursor-not-allowed" href="#">Blog</a></li>
            <li><a class="disabled text-mandy-white/40 cursor-not-allowed" href="#">Recomendations</a></li>
            <li><a class="disabled text-mandy-white/40 cursor-not-allowed" href="#">Guest Book</a></li>
            <li><a class="disabled text-mandy-white/40 cursor-not-allowed" href="#">DIY Projects</a></li>
            <li><a class="disabled text-mandy-white/40 cursor-not-allowed" href="#">Stuff</a></li>
          </ul>
        </nav>
      </aside>

      <div class="flex flex-col gap-5 flex-1">
        <main class="flex-1">
          <Bento />
        </main>
        
        <div class="p-10 flex items-center justify-center">
          <StampsScroll />
        </div>
      </div>
      
    </div>
  </div>
</Layout>