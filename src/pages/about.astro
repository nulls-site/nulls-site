---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Investigator Sheet | null's site">
  <div class="min-h-screen px-4 md:px-10 py-6 bg-[var(--theme-bg)]">

    <!-- Chapter title card -->
    <div class="chapter-card mb-4">
      <span class="chapter-number">∴ &nbsp; Chapter II &nbsp; ∴</span>
      <span class="chapter-title">Children of the New Dawn</span>
      <div class="chapter-rule">⸸</div>
    </div>

    <!-- Main container -->
    <div
      class="max-w-6xl mx-auto border-4 rounded-lg p-6 shadow-2xl"
      style="background: var(--theme-surface-muted); border-color: var(--theme-border);"
    >

      <!-- Top grid: photo + characteristics -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">

        <!-- Photo & basic info -->
        <div class="border-2 p-4" style="border-color: var(--theme-border); background: var(--theme-surface);">
          <div
            class="aspect-square rounded mb-3 flex items-center justify-center"
            style="background: var(--theme-surface-muted);"
          >
            <span class="text-sm" style="color: var(--theme-text-subtle);">[Photo]</span>
          </div>
          <div class="space-y-2 text-sm">
            <p class="border-b pb-1" style="border-color: var(--theme-border-muted);">
              <strong style="color: var(--theme-accent-bright);">Name:</strong>
              <span style="color: var(--theme-text);"> Null</span>
            </p>
            <p class="border-b pb-1" style="border-color: var(--theme-border-muted);">
              <strong style="color: var(--theme-accent-bright);">Occupation:</strong>
              <span style="color: var(--theme-text);"> Data Engineer Intern</span>
            </p>
            <p class="border-b pb-1" style="border-color: var(--theme-border-muted);">
              <strong style="color: var(--theme-accent-bright);">Age:</strong>
              <span style="color: var(--theme-text);"> 23</span>
            </p>
            <p class="border-b pb-1" style="border-color: var(--theme-border-muted);">
              <strong style="color: var(--theme-accent-bright);">Birthplace:</strong>
              <span style="color: var(--theme-text);"> Brazil 🇧🇷</span>
            </p>
            <p>
              <strong style="color: var(--theme-accent-bright);">Status Ailment:</strong>
              <span style="color: var(--theme-text);"> ADHD &amp; mixed disorder</span>
            </p>
          </div>
        </div>

        <!-- Characteristics -->
        <div class="border-2 p-4 md:col-span-2" style="border-color: var(--theme-border); background: var(--theme-surface);">
          <h2 class="text-xl font-bold mb-4 border-b-2 pb-2" style="color: var(--theme-accent-bright); border-color: var(--theme-border);">
            CHARACTERISTICS
          </h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
            {Array.from({ length: 9 }).map(() => (
              <div class="text-center">
                <p class="text-xs mb-1" style="color: var(--theme-text-muted);"></p>
                <div class="border-2 h-16 flex items-center justify-center text-2xl font-bold"
                     style="border-color: var(--theme-border); background: var(--theme-bg); color: var(--theme-text);">
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Status bars -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="border-2 p-3 text-center" style="border-color: var(--theme-border); background: var(--theme-surface);">
          <p class="text-xs mb-2" style="color: var(--theme-text-muted);">HIT POINTS</p>
          <div class="flex justify-center gap-2">
            <div class="border px-3 py-1 text-sm" style="border-color: var(--theme-border); color: var(--theme-text);">Current: 8</div>
            <div class="border px-3 py-1 text-sm" style="border-color: var(--theme-border); color: var(--theme-text);">Max: 12</div>
          </div>
        </div>

        <div class="border-2 p-3 text-center" style="border-color: var(--theme-border); background: var(--theme-surface);">
          <p class="text-xs mb-2" style="color: var(--theme-text-muted);">SANITY</p>
          <div class="flex justify-center gap-2">
            <div class="border px-3 py-1 text-sm" style="border-color: var(--theme-border); color: var(--theme-accent-bright);">Current: 20</div>
            <div class="border px-3 py-1 text-sm" style="border-color: var(--theme-border); color: var(--theme-text);">Max: 70</div>
          </div>
        </div>

        <div class="border-2 p-3 text-center" style="border-color: var(--theme-border); background: var(--theme-surface);">
          <p class="text-xs mb-2" style="color: var(--theme-text-muted);"></p>
          <div class="border px-4 py-1 text-sm inline-block" style="border-color: var(--theme-border); color: var(--theme-text);"></div>
        </div>

        <div class="border-2 p-3 text-center" style="border-color: var(--theme-border); background: var(--theme-surface);">
          <p class="text-xs mb-2" style="color: var(--theme-text-muted);"></p>
          <div class="border px-4 py-1 text-sm inline-block" style="border-color: var(--theme-border); color: var(--theme-text);"></div>
        </div>
      </div>

      <!-- Skills -->
      <div class="border-2 p-4 mb-6" style="border-color: var(--theme-border); background: var(--theme-surface);">
        <h2 class="text-xl font-bold mb-4 border-b-2 pb-2" style="color: var(--theme-accent-bright); border-color: var(--theme-border);">
          SKILLS &amp; INTERESTS
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

          <div>
            <h3 class="text-sm font-bold mb-2" style="color: var(--theme-accent-bright);">PROFESSIONAL</h3>
            <div class="space-y-2">
              <div class="flex justify-between items-center border-b pb-1" style="border-color: var(--theme-border-muted);">
                <span class="text-sm" style="color: var(--theme-text);">Data Engineering</span>
                <span class="text-sm font-bold" style="color: var(--theme-highlight);">40%</span>
              </div>
              <div class="flex justify-between items-center border-b pb-1" style="border-color: var(--theme-border-muted);">
                <span class="text-sm" style="color: var(--theme-text);">Computer Science</span>
                <span class="text-sm font-bold" style="color: var(--theme-highlight);">70%</span>
              </div>
              <div class="flex justify-between items-center border-b pb-1" style="border-color: var(--theme-border-muted);">
                <span class="text-sm" style="color: var(--theme-text);">Electronics</span>
                <span class="text-sm font-bold" style="color: var(--theme-highlight);">10%</span>
              </div>
              <div class="flex justify-between items-center border-b pb-1" style="border-color: var(--theme-border-muted);">
                <span class="text-sm" style="color: var(--theme-text);">Product Design</span>
                <span class="text-sm font-bold" style="color: var(--theme-highlight);">1%</span>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-sm font-bold mb-2" style="color: var(--theme-accent-bright);">PERSONAL</h3>
            <div class="space-y-2">
              <div class="flex justify-between items-center border-b pb-1" style="border-color: var(--theme-border-muted);">
                <span class="text-sm" style="color: var(--theme-text);">Mandarin (HSK02)</span>
                <span class="text-sm font-bold" style="color: var(--theme-highlight);">40%</span>
              </div>
              <div class="flex justify-between items-center border-b pb-1" style="border-color: var(--theme-border-muted);">
                <span class="text-sm" style="color: var(--theme-text);"></span>
                <span class="text-sm font-bold" style="color: var(--theme-highlight);"></span>
              </div>
              <div class="flex justify-between items-center border-b pb-1" style="border-color: var(--theme-border-muted);">
                <span class="text-sm" style="color: var(--theme-text);"></span>
                <span class="text-sm font-bold" style="color: var(--theme-highlight);"></span>
              </div>
              <div class="flex justify-between items-center border-b pb-1" style="border-color: var(--theme-border-muted);">
                <span class="text-sm" style="color: var(--theme-text);"></span>
                <span class="text-sm font-bold" style="color: var(--theme-highlight);"></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Current Quest -->
      <div class="border-2 p-4 mb-6" style="border-color: var(--theme-border); background: var(--theme-surface);">
        <h2 class="text-xl font-bold mb-3 border-b-2 pb-2" style="color: var(--theme-accent-bright); border-color: var(--theme-border);">
          CURRENT QUEST
        </h2>
        <p class="text-sm leading-relaxed" style="color: var(--theme-text);">
          Currently exploring quest <strong style="color: var(--theme-highlight);">Obtain CS Degree</strong>.<br />
          <span class="text-xs italic" style="color: var(--theme-accent-bright);">Failing due to sanity loss.</span>
        </p>
      </div>

      <!-- Backstory -->
      <div class="border-2 p-4 mb-6" style="border-color: var(--theme-border); background: var(--theme-surface);">
        <h2 class="text-xl font-bold mb-3 border-b-2 pb-2" style="color: var(--theme-accent-bright); border-color: var(--theme-border);">
          BACKSTORY
        </h2>
        <p class="text-sm leading-relaxed" style="color: var(--theme-text);">
          This investigator rushed into building their digital realm 8 months ago,
          only to abandon it in the depths of burnout.
          <br /><br />
          Seeking a career path that combines creativity with technology.
        </p>
      </div>

      <!-- Companions (empty) -->
      <div class="border-2 p-4" style="border-color: var(--theme-border); background: var(--theme-surface);">
        <h2 class="text-xl font-bold mb-3 border-b-2 pb-2" style="color: var(--theme-accent-bright); border-color: var(--theme-border);"></h2>
        <div class="flex flex-wrap gap-2"></div>
      </div>

      <!-- Footer -->
      <div class="mt-6 text-center border-t-4 pt-4" style="border-color: var(--theme-border);">
        <a
          href="/"
          class="inline-block px-6 py-2 text-sm font-semibold rounded transition-all duration-300"
          style="background: var(--theme-surface); border: 1px solid var(--theme-border); color: var(--theme-text);"
          onmouseover="this.style.background='var(--theme-accent-bright)'; this.style.color='var(--theme-bg)';"
          onmouseout="this.style.background='var(--theme-surface)'; this.style.color='var(--theme-text)';"
        >
          ← Return to Hub
        </a>
      </div>
    </div>
  </div>
</Layout>
