---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title={`${post.data.title} | null's site`}>
  <div class="min-h-screen px-4 md:px-20 py-6">

    <!-- Back link -->
    <nav aria-label="Breadcrumb" class="mb-6">
      <a
        href="/blog"
        class="grimoire-label inline-flex items-center gap-2 transition-colors duration-200"
        style="font-size: 0.55rem;"
        onmouseover="this.style.color='var(--theme-accent-bright)'"
        onmouseout="this.style.color=''"
      >
        ← Chronicles
      </a>
    </nav>

    <!-- Post header -->
    <header class="mb-8">
      <div class="chapter-card" style="text-align: left; padding-top: 0;">
        <span class="chapter-number" style="text-align: left;">
          ∴ &nbsp; Entry &nbsp; ∴
        </span>
        <h1 class="chapter-title" style="font-size: clamp(1.2rem, 4vw, 2.2rem); text-align: left;">
          {post.data.title}
        </h1>
        <div class="chapter-rule" style="justify-content: flex-start;">⸸</div>
      </div>

      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-4 mt-4">
        <time
          datetime={post.data.date.toISOString()}
          class="grimoire-label"
          style="font-size: 0.5rem;"
        >
          {formatDate(post.data.date)}
        </time>
        {post.data.tags.length > 0 && (
          <ul class="flex flex-wrap gap-1" aria-label="Tags">
            {post.data.tags.map(tag => (
              <li
                class="grimoire-label px-2 py-0.5"
                style="font-size: 0.45rem; border: 1px solid var(--theme-border-muted);"
              >
                {tag}
              </li>
            ))}
          </ul>
        )}
      </div>

      <p class="mt-4 text-sm italic" style="color: var(--theme-text-muted); max-width: 60ch;">
        {post.data.description}
      </p>
    </header>

    <!-- Post body -->
    <main id="main-content">
      <article class="prose max-w-3xl" aria-label={post.data.title}>
        <Content />
      </article>
    </main>

    <!-- Footer nav -->
    <footer class="mt-16 pt-6" style="border-top: 1px solid var(--theme-border);">
      <div class="sigil-divider mb-6">⸸</div>
      <div class="flex justify-between items-center flex-wrap gap-4">
        <a
          href="/blog"
          class="grimoire-label inline-block px-5 py-2 transition-colors duration-200"
          style="border: 1px solid var(--theme-border); font-size: 0.55rem;"
          onmouseover="this.style.borderColor='var(--theme-accent-bright)'; this.style.color='var(--theme-accent-bright)'"
          onmouseout="this.style.borderColor='var(--theme-border)'; this.style.color=''"
        >
          ← All Entries
        </a>
        <a
          href="/"
          class="grimoire-label inline-block px-5 py-2 transition-colors duration-200"
          style="border: 1px solid var(--theme-border); font-size: 0.55rem;"
          onmouseover="this.style.borderColor='var(--theme-accent-bright)'; this.style.color='var(--theme-accent-bright)'"
          onmouseout="this.style.borderColor='var(--theme-border)'; this.style.color=''"
        >
          Return to Domain →
        </a>
      </div>
    </footer>

  </div>
</Layout>
